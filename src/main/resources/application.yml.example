# SreAgent 配置文件模板
# 复制此文件为 application.yml 并填入你的配置值

server:
  port: 9900
  servlet:
    encoding:
      charset: UTF-8
      enabled: true
      force: true

file:
  upload:
    path: ./uploads
    allowed-extensions: txt,md

milvus:
  host: 127.0.0.1           # Milvus 服务器地址
  port: 19530               # Milvus 服务器端口
  username: ""              # Milvus 用户名（如有）
  password: ""              # Milvus 密码（如有）
  database: default         # 数据库名称
  timeout: 30000

# Spring AI Alibaba DashScope 配置
spring:
  ai:
    dashscope:
      api-key: YOUR_DASHSCOPE_API_KEY  # 替换为你的阿里云 DashScope API Key
      chat:
        options:
          timeout: 180000
      retry:
        max-attempts: 3
        backoff:
          initial-interval: 2000
          multiplier: 2
          max-interval: 10000

# 阿里云 DashScope Embedding API 配置
dashscope:
  api:
    key: YOUR_DASHSCOPE_API_KEY  # 替换为你的阿里云 DashScope API Key
  embedding:
    model: text-embedding-v4

# 文档分片配置
document:
  chunk:
    max-size: 800
    overlap: 100

# RAG 配置
rag:
  top-k: 3
  model: "qwen3-max"

# Prometheus 配置
prometheus:
  base-url: http://localhost:9090
  timeout: 10
  mock-enabled: true

# CLS 云日志服务配置
cls:
  mock-enabled: true
